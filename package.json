{
  "name": "dafghif-learning-portfolio",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "serve": "vite preview --host 127.0.0.1",
    "generate:portfolio": "bun scripts/portfolio-generation-command.ts",
    "lint": "bun scripts/validate-site.ts",
    "budget": "bun scripts/check-performance-budget.ts",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:system": "bun test test/system",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "validate": "bun scripts/validate-site.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "happy-dom": "^20.11.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "overrides": {
    "ws": "8.21.1"
  }
}
